@model formulario_olv.Models.HistorialLegajoViewModel
@{
    ViewData["Title"] = "Historial de Legajo";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <!-- Botón volver -->
            <div class="mb-3">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Volver a la búsqueda
                </a>
            </div>

            <!-- Ficha de identificación -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-person-badge me-2"></i>Ficha de Identificación
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <!-- Foto -->
                        <div class="col-md-3 col-lg-2 text-center mb-3 mb-md-0">
                            <div class="border rounded p-3 bg-light" style="min-height: 150px;">
                                <img src="~/Inicio/Foto/@Model.IdLegajo"                                     alt="Foto"
                                     class="img-fluid rounded"
                                     style="max-height: 140px;"
                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                                <div style="display: none;">
                                    <i class="bi bi-person-circle display-1 text-muted"></i>
                                    <p class="small text-muted mb-0 mt-2">Sin foto</p>
                                </div>
                            </div>
                        </div>

                        <!-- Datos principales -->
                        <div class="col-md-9 col-lg-10">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small mb-0">Legajo</label>
                                    <div class="fw-bold fs-5">@Model.NumeroLegajo</div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small mb-0">DNI</label>
                                    <div class="fw-bold">@Model.DNI</div>
                                </div>
                                <div class="col-12 mb-3">
                                    <label class="form-label text-muted small mb-0">Nombre y Apellido</label>
                                    <div class="fw-bold fs-5">@Model.NombreApellido</div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small mb-0">Delito</label>
                                    <div>@Model.Delito</div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small mb-0">Nivel de Riesgo</label>
                                    <div>
                                        @{
                                            var badgeClass = Model.NivelRiesgo?.ToLower() switch
                                            {
                                                "alto" => "bg-danger",
                                                "medio" => "bg-warning text-dark",
                                                "bajo" => "bg-success",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass fs-6">@Model.NivelRiesgo</span>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small mb-0">Modalidad de Tutela</label>
                                    <div>@Model.ModalidadTutela</div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small mb-0">Periodicidad de Entrevistas</label>
                                    <div>@Model.PeriodicidadEntrevistas</div>
                                </div>
                                <div class="col-12 mb-3">
                                    <label class="form-label text-muted small mb-0">Dirección</label>
                                    <div>
                                        <i class="bi bi-geo-alt me-1 text-muted"></i>@(string.IsNullOrEmpty(Model.Direccion) ? "No especificada" : Model.Direccion)
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Historial de entrevistas -->
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-clock-history me-2"></i>Historial de Entrevistas
                    </h5>
                    <a asp-controller="Entrevista"
                       asp-action="Index"
                       asp-route-idLegajo="@Model.IdLegajo"
                       asp-route-tipoLegajoId="@Model.TipoLegajoId"
                       class="btn btn-success">
                        <i class="bi bi-plus-circle me-1"></i> Nueva Entrevista
                    </a>
                </div>
                <div class="card-body p-0">
                    @if (Model.Entrevistas.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-striped mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col" class="text-center">N°</th>
                                        <th scope="col">Fecha y Hora</th>
                                        <th scope="col" class="text-center">Domicilio Verificado</th>
                                        <th scope="col">Domicilio</th>
                                        <th scope="col">Cierre</th>
                                        <th scope="col">Usuario</th>
                                        <th scope="col" class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entrevista in Model.Entrevistas.OrderByDescending(e => e.NumeroEntrevista))
                                    {
                                        <tr>
                                            <td class="text-center">
                                                <span class="badge bg-primary rounded-pill">@entrevista.NumeroEntrevista</span>
                                            </td>
                                            <td>
                                                <div>@entrevista.FechaHora.ToString("dd/MM/yyyy")</div>
                                                <small class="text-muted">@entrevista.FechaHora.ToString("HH:mm")</small>
                                            </td>
                                            <td class="text-center">
                                                @if (entrevista.DomicilioVerificado == true)
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="bi bi-check-circle me-1"></i>Verificado
                                                    </span>
                                                }
                                                else if (entrevista.DomicilioVerificado == false)
                                                {
                                                    <span class="badge bg-danger">
                                                        <i class="bi bi-x-circle me-1"></i>No Verificado
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(entrevista.Domicilio))
                                                {
                                                    <small>
                                                        <i class="bi bi-geo-alt me-1 text-muted"></i>@entrevista.Domicilio
                                                    </small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(entrevista.Cierre))
                                                {
                                                    <span>@entrevista.Cierre</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                <small>@entrevista.UsuarioCreacion</small>
                                            </td>
                                            <td class="text-center">
                                                <a asp-action="VerEntrevista"
                                                   asp-route-id="@entrevista.Id"
                                                   class="btn btn-sm btn-outline-info">
                                                    <i class="bi bi-eye me-1"></i> Ver
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-journal-x display-1 text-muted"></i>
                            <h4 class="mt-3 text-muted">Sin entrevistas registradas</h4>
                            <p class="text-muted">Este legajo aún no tiene entrevistas realizadas.</p>
                            <a asp-controller="Entrevista"
                               asp-action="Index"
                               asp-route-idLegajo="@Model.IdLegajo"
                               asp-route-tipoLegajoId="@Model.TipoLegajoId"
                               class="btn btn-success btn-lg">
                                <i class="bi bi-plus-circle me-1"></i> Crear Primera Entrevista
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
